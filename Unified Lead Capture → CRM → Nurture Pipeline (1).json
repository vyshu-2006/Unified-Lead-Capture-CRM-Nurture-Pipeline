    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst leads = items.map(i => i.json);\n\nconst bySource = {};\nconst byTemp = {};\n\nfor (const lead of leads) {\n  const source = lead.lead_source || lead.source || 'Unknown';\n  const temp = lead.hs_lead_status || lead.lead_temperature || 'unknown';\n  bySource[source] = (bySource[source] || 0) + 1;\n  byTemp[temp] = (byTemp[temp] || 0) + 1;\n}\n\nconst summaryLines = [\n  `Total leads this week: ${leads.length}`,\n  '',\n  'By source:',\n  ...Object.entries(bySource).map(([k, v]) => `  - ${k}: ${v}`),\n  '',\n  'By temperature:',\n  ...Object.entries(byTemp).map(([k, v]) => `  - ${k}: ${v}`)\n];\n\nreturn {\n  json: {\n    total: leads.length,\n    by_source: bySource,\n    by_temperature: byTemp,\n    summary_text: summaryLines.join('\\n')\n  }\n};"
      },
