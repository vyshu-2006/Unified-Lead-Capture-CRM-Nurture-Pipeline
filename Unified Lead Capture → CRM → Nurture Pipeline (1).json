        80,
        368
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const d = $input.item.json.body || $input.item.json;\n\nreturn {\n  json: {\n    name: `${d['First Name'] || d.first_name || ''} ${d['Last Name'] || d.last_name || ''}`.trim(),\n    email: d['Email Address'] || d.email || '',\n    phone: d['Phone Number'] || d.phone || '',\n    company: d['Company Name'] || d.company || '',\n    company_size: d['Company Size'] || 'unknown',\n    message: d['Job Title'] || '',\n    source: 'LinkedIn Lead Gen',\n    engagement_signal: 'linkedin_form',\n    received_at: new Date().toISOString()\n  }\n};"
      },
      "id": "7714e409-f828-40f3-8c2c-6e247657a003",
      "name": "Normalize LinkedIn Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        80,
        592
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const body = $input.item.json.body || $input.item.json;\nconst entry = body.entry && body.entry[0];\nconst change = entry && entry.changes && entry.changes[0] && entry.changes[0].value;\nconst msg = change && change.messages && change.messages[0];\nconst contact = change && change.contacts && change.contacts[0];\n\nreturn {\n  json: {\n    name: (contact && contact.profile && contact.profile.name) || 'WhatsApp Lead',\n    email: '',\n    phone: (msg && msg.from) || '',\n    company: '',\n    company_size: 'unknown',\n    message: (msg && msg.text && msg.text.body) || '',\n    source: 'WhatsApp',\n    engagement_signal: 'whatsapp_message',\n    received_at: new Date().toISOString()\n  }\n};"
      },
      "id": "b3ddde1d-6415-41dc-b12b-cac82e6a72a4",
      "name": "Normalize WhatsApp Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        80,
        816
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item.json;\nlet score = 0;\n\n// Company size scoring\nconst sizeMap = { '1-10': 5, '11-50': 15, '51-200': 25, '201-500': 35, '500+': 40, 'unknown': 10 };\nscore += sizeMap[item.company_size] ?? 10;\n\n// Source scoring\nconst sourceMap = { 'Website Form': 25, 'LinkedIn Lead Gen': 30, 'WhatsApp': 20 };\nscore += sourceMap[item.source] ?? 10;\n\n// Engagement scoring\nif (item.message && item.message.length > 20) score += 15;\nif (item.email) score += 10;\nif (item.phone) score += 10;\n\nscore = Math.min(score, 100);\n\nlet lead_temperature = 'cold';\nif (score >= 70) lead_temperature = 'hot';\nelse if (score >= 40) lead_temperature = 'warm';\n\nreturn {\n  json: {\n    ...item,\n    lead_score: score,\n    lead_temperature\n  }\n};"
      },
