      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const body = $input.item.json.body || $input.item.json;\n\nreturn {\n  json: {\n    name: body.name || body.full_name || '',\n    email: body.email || '',\n    phone: body.phone || body.phone_number || '',\n    company: body.company || '',\n    company_size: body.company_size || body.employees || 'unknown',\n    message: body.message || '',\n    source: 'Website Form',\n    engagement_signal: 'form_submission',\n    received_at: new Date().toISOString()\n  }\n};"
      },
      "id": "24746326-dee2-4ca8-9c60-7ea9553832eb",
      "name": "Normalize Website Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
